# ==============================================================
# Pakasian ERP System - .gitignore
# ==============================================================

# ---------------------------------------------------------------
# Python Virtual Environments
# ---------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/
venv.bak/

# ---------------------------------------------------------------
# Python Cache & Compiled Files
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ---------------------------------------------------------------
# Django Specific
# ---------------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/

# ---------------------------------------------------------------
# Environment Variables & Secrets
# ---------------------------------------------------------------
.env
.env.*
!.env.example
*.env
secrets.json

# ---------------------------------------------------------------
# Distribution / Packaging
# ---------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ---------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
coverage.xml
*.cover
nosetests.xml

# ---------------------------------------------------------------
# IDEs & Editors
# ---------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------
# Node / Frontend (erp-frontend)
# ---------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
erp-frontend/dist/
erp-frontend/build/
erp-frontend/.env

# ---------------------------------------------------------------
# Jupyter Notebooks
# ---------------------------------------------------------------
.ipynb_checkpoints
*.ipynb

# ---------------------------------------------------------------
# Misc
# ---------------------------------------------------------------
*.bak
*.tmp
*.orig
*.pid
celerybeat-schedule
celerybeat.pid
